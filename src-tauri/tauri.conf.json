{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/schemas/tauri.conf.schema.json",
  "productName": "RAM-Stream-Browser",
  "version": "0.1.0",
  "identifier": "com.ram-stream-browser.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run serve --prefix C:\\Users\\WBLbo\\Documents\\GitHub\\RAM-Stream-Browser",
    "beforeBuildCommand": ""
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
